generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  nickname        String          @unique
  createdAt       DateTime        @default(now())
  password        String
  credits         Int             @default(0)
  models          Model[]
  offModels       OffModel[]
  renderedImages  RenderedImage[]
  friendsAsRequester Friend[]     @relation("Requester")
  friendsAsAddressee Friend[]     @relation("Addressee")
  sentGifts       ModelGift[]     @relation("Sender")
  receivedGifts   ModelGift[]     @relation("Receiver")
}

model Model {
  id              String      @id @default(cuid())
  createdAt       DateTime    @default(now())
  userId          String
  key             String
  user            User        @relation(fields: [userId], references: [id])
  offering_models OffModel[]
  gifts           ModelGift[]
}

model Category {
  id        String     @id @default(cuid())
  name      String     @unique
  createdAt DateTime   @default(now())
  offModels OffModel[]
}

model OffModel {
  id          String    @id @default(cuid())
  name        String
  description String
  price       Float
  modelId     String?
  createdAt   DateTime  @default(now())
  userId      String
  key         String    @unique
  categoryId  String?
  model       Model?    @relation(fields: [modelId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
  category    Category? @relation(fields: [categoryId], references: [id])
}

model RenderedImage {
  id        String   @id @default(cuid())
  userId    String
  key       String   @unique
  title     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

enum FriendStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model Friend {
  id          String       @id @default(cuid())
  requesterId String
  addresseeId String
  status      FriendStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  requester   User         @relation("Requester", fields: [requesterId], references: [id])
  addressee   User         @relation("Addressee", fields: [addresseeId], references: [id])

  @@unique([requesterId, addresseeId])
}

model ModelGift {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  modelId    String
  message    String?
  seen       Boolean  @default(false)
  createdAt  DateTime @default(now())
  sender     User     @relation("Sender", fields: [senderId], references: [id])
  receiver   User     @relation("Receiver", fields: [receiverId], references: [id])
  model      Model    @relation(fields: [modelId], references: [id])
}
